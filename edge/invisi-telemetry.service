[Unit]
Description=Invisi Telemetry Pipeline
After=network.target mosquitto.service redis-server.service
Wants=mosquitto.service redis-server.service

[Service]
Type=simple
User=invisi
WorkingDirectory=/home/invisi/invisi/nextjs-app
EnvironmentFile=-/home/invisi/invisi/nextjs-app/.env.local
ExecStart=/home/invisi/.bun/bin/bun run telemetry/index.ts
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
